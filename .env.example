# Copy to .env for local dev, or set in Netlify → Site settings →
# Environment variables. Without these, the site and Team Portal run
# in DEMO mode (portal changes stay in the browser).
#
# 1. Create a free project at supabase.com
# 2. Run supabase/schema.sql in the SQL editor
# 3. Paste these from Project Settings → API:
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
